{
  "name": "cheesyguide",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "convex dev --start \"bun run dev\"",
    "codex": "bun install && bunx convex dev --start \"bun run dev\"",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview",
    "firebase:emulate": "bunx firebase-tools@latest emulators:start --only hosting",
    "deploy": "bun run build && bunx firebase-tools@latest deploy --only hosting,storage"
  },
  "dependencies": {
    "@auth/core": "0.41.1",
    "@base-ui/react": "^1.6.0",
    "@convex-dev/auth": "^0.0.94",
    "@firebase/ai": "^2.13.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^2.10.0",
    "@noble/hashes": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "firebase": "^12.15.0",
    "lucide-react": "^1.22.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
